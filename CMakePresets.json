{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 28, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "CMAKE_EXPORT_COMPILE_COMMANDS": "ON" }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
    },
    {
      "name": "release",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "AETHER_REQUIRE_METAL_TOOLCHAIN": "ON"
      }
    },
    {
      "name": "sanitizer",
      "inherits": "debug",
      "cacheVariables": {
        "AETHER_BUILD_STUDIO": "OFF",
        "AETHER_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "ci",
      "inherits": "debug",
      "cacheVariables": {
        "AETHER_BUILD_STUDIO": "OFF",
        "AETHER_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "debug", "configurePreset": "debug" },
    { "name": "release", "configurePreset": "release" },
    { "name": "sanitizer", "configurePreset": "sanitizer" },
    { "name": "ci", "configurePreset": "ci" }
  ],
  "testPresets": [
    { "name": "debug", "configurePreset": "debug", "output": { "outputOnFailure": true } },
    { "name": "ci", "configurePreset": "ci", "output": { "outputOnFailure": true } }
  ]
}
